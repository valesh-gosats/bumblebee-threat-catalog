BASE="$HOME/security"
CATALOG_REPO="$HOME/security/bumblebee-threat-catalog"
CATALOG_DIR="$CATALOG_REPO/catalogs"
OUTDIR="$BASE/bumblebee-runs"
GIT_REMOTE="origin"
GIT_BRANCH="main"
SCAN_PROFILE="deep"
SCAN_ROOT="$HOME"
MAX_DURATION="10m"
DAILY_SCAN_PROFILE="deep"
DAILY_SCAN_ROOT="$HOME"
DAILY_MAX_DURATION="30m"
NOTIFY_DESKTOP="true"

